<QuestionList name="" type="Pre-employment">
    <Question>
        <Number>1</Number>
        <ID>X</ID>
        <Type>Start of Chart</Type>
        <Text>This test is about to begin, please remain still. </Text>
    </Question>
    <Question>
        <Number>2</Number>
        <ID>N1</ID>
        <Type>Irrelevant / Neutral</Type>
        <Text>Are the lights on in this room?</Text>
        <ExpectedResponse>Yes</ExpectedResponse>
    </Question>
    <Question>
        <Number>3</Number>
        <ID>N2</ID>
        <Type>Irrelevant / Neutral</Type>
        <Text>Are you sitting down?</Text>
        <ExpectedResponse>Yes</ExpectedResponse>
    </Question>
    <Question>
        <Number>4</Number>
        <ID>SR</ID>
        <Type>Sacrifice Relevant</Type>
        <Text>Do you intend to answer the crime related questions truthfully?</Text>
        <ExpectedResponse>Yes</ExpectedResponse>
    </Question>
    <Question>
        <Number>5</Number>
        <ID>1C1</ID>
        <Type>Control / Comparison</Type>
        <Text>Prior to applying with DPS, did you ever tell even one lie?</Text>
        <ExpectedResponse>No</ExpectedResponse>
    </Question>
    <Question>
        <Number>6</Number>
        <ID>1R1</ID>
        <Type>Relevant</Type>
        <Text>Are you now withholding any information about your involvement in a crime against a person?</Text>
